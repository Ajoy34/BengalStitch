generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────

enum UserRole {
  USER
  CREATOR
  ADMIN
  AFFILIATE
}

enum SubscriptionTier {
  FREE
  PRO
  BRAND
  ENTERPRISE
}

enum PayoutMethod {
  BKASH
  NAGAD
  BANK
  PAYPAL
  WISE
  PAYONEER
}

enum ProductType {
  TSHIRT
  HOODIE
  MUG
  PHONE_CASE
  TOTE_BAG
  POSTER
  CAP
  SHOES
  JEWELRY
}

enum ProductStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum DesignPlacement {
  FRONT
  BACK
  LEFT
  RIGHT
  ALL_OVER
}

enum StockStatus {
  IN_STOCK
  LOW
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  PRINTED
  SHIPPED
  DELIVERED
  RETURNED
  CANCELLED
}

enum PaymentGateway {
  BKASH
  NAGAD
  ROCKET
  SSLCOMMERZ
  STRIPE
  PAYPAL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum NotificationType {
  ORDER
  PAYMENT
  PAYOUT
  SYSTEM
  PROMO
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

// ─── Models ────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  phone        String?  @db.VarChar(20)
  fullName     String   @map("full_name") @db.VarChar(255)
  avatarUrl    String?  @map("avatar_url")
  country      String   @default("BD") @db.VarChar(2)
  language     String   @default("en") @db.VarChar(5)
  role         UserRole @default(USER)
  isVerified   Boolean  @default(false) @map("is_verified")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  creatorProfile CreatorProfile?
  orders         Order[]
  reviews        Review[]
  favorites      Favorite[]
  cart           Cart?
  notifications  NotificationLog[]
  affiliateLinks AffiliateLink[]

  @@index([role])
  @@index([country])
  @@map("users")
}

model CreatorProfile {
  id               String           @id @default(uuid())
  userId           String           @unique @map("user_id")
  storeName        String           @unique @map("store_name") @db.VarChar(100)
  storeSlug        String           @unique @map("store_slug") @db.VarChar(100)
  bio              String?
  logoUrl          String?          @map("logo_url")
  bannerUrl        String?          @map("banner_url")
  customDomain     String?          @unique @map("custom_domain") @db.VarChar(255)
  domainVerified   Boolean          @default(false) @map("domain_verified")
  themeColor       String?          @default("#6c3ce9") @map("theme_color") @db.VarChar(7)
  heroTitle        String?          @map("hero_title") @db.VarChar(255)
  heroSubtitle     String?          @map("hero_subtitle")
  socialLinks      Json?            @map("social_links")
  subscriptionTier SubscriptionTier @default(FREE) @map("subscription_tier")
  commissionRate   Decimal          @default(20.00) @map("commission_rate") @db.Decimal(5, 2)
  totalEarnings    Decimal          @default(0) @map("total_earnings") @db.Decimal(12, 2)
  totalSales       Int              @default(0) @map("total_sales")
  payoutMethod     PayoutMethod?    @map("payout_method")
  payoutDetails    Json?            @map("payout_details")
  isVerifiedSeller Boolean          @default(false) @map("is_verified_seller")
  createdAt        DateTime         @default(now()) @map("created_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  products       Product[]
  orderItems     OrderItem[]
  payouts        Payout[]
  affiliateLinks AffiliateLink[]
  subscription   Subscription?

  @@index([subscriptionTier])
  @@index([customDomain])
  @@map("creator_profiles")
}

model Product {
  id             String        @id @default(uuid())
  creatorId      String        @map("creator_id")
  title          String        @db.VarChar(255)
  slug           String        @unique @db.VarChar(255)
  description    String?
  productType    ProductType   @map("product_type")
  basePrice      Decimal       @map("base_price") @db.Decimal(10, 2)
  sellingPrice   Decimal       @map("selling_price") @db.Decimal(10, 2)
  profitMargin   Decimal       @map("profit_margin") @db.Decimal(10, 2)
  currency       String        @default("BDT") @db.VarChar(3)
  status         ProductStatus @default(DRAFT)
  tags           String[]
  seoTitle       String?       @map("seo_title") @db.VarChar(255)
  seoDescription String?       @map("seo_description")
  viewCount      Int           @default(0) @map("view_count")
  saleCount      Int           @default(0) @map("sale_count")
  isFeatured     Boolean       @default(false) @map("is_featured")
  mockupUrls     Json?         @map("mockup_urls")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  creator        CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  variants       ProductVariant[]
  designs        ProductDesign[]
  orderItems     OrderItem[]
  reviews        Review[]
  favorites      Favorite[]
  affiliateLinks AffiliateLink[]

  @@index([creatorId])
  @@index([productType])
  @@index([status])
  @@index([isFeatured])
  @@index([createdAt(sort: Desc)])
  @@index([saleCount(sort: Desc)])
  @@map("products")
}

model ProductVariant {
  id              String      @id @default(uuid())
  productId       String      @map("product_id")
  size            String?     @db.VarChar(10)
  color           String?     @db.VarChar(50)
  colorHex        String?     @map("color_hex") @db.VarChar(7)
  sku             String      @unique @db.VarChar(100)
  additionalPrice Decimal     @default(0) @map("additional_price") @db.Decimal(10, 2)
  stockStatus     StockStatus @default(IN_STOCK) @map("stock_status")
  weightGrams     Int?        @map("weight_grams")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  cartItems  CartItem[]

  @@index([productId])
  @@map("product_variants")
}

model ProductDesign {
  id           String          @id @default(uuid())
  productId    String          @map("product_id")
  designUrl    String          @map("design_url")
  thumbnailUrl String          @map("thumbnail_url")
  placement    DesignPlacement @default(FRONT)
  positionX    Float           @default(50) @map("position_x")
  positionY    Float           @default(50) @map("position_y")
  scale        Float           @default(100)
  rotation     Float           @default(0)
  layers       Json?
  createdAt    DateTime        @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_designs")
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique @map("order_number") @db.VarChar(20)
  buyerId         String      @map("buyer_id")
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(12, 2)
  shippingCost    Decimal     @default(0) @map("shipping_cost") @db.Decimal(10, 2)
  tax             Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(12, 2)
  currency        String      @default("BDT") @db.VarChar(3)
  shippingAddress Json        @map("shipping_address")
  trackingNumber  String?     @map("tracking_number") @db.VarChar(100)
  courier         String?     @db.VarChar(50)
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  buyer    User        @relation(fields: [buyerId], references: [id])
  items    OrderItem[]
  payments Payment[]

  @@index([buyerId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

model OrderItem {
  id             String  @id @default(uuid())
  orderId        String  @map("order_id")
  productId      String  @map("product_id")
  variantId      String  @map("variant_id")
  creatorId      String  @map("creator_id")
  quantity       Int
  unitPrice      Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice     Decimal @map("total_price") @db.Decimal(10, 2)
  designSnapshot Json?   @map("design_snapshot")

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])
  creator CreatorProfile @relation(fields: [creatorId], references: [id])

  @@index([orderId])
  @@index([creatorId])
  @@map("order_items")
}

model Payment {
  id              String         @id @default(uuid())
  orderId         String         @map("order_id")
  gateway         PaymentGateway
  gatewayTxnId    String?        @map("gateway_txn_id") @db.VarChar(255)
  amount          Decimal        @db.Decimal(12, 2)
  currency        String         @db.VarChar(3)
  status          PaymentStatus  @default(PENDING)
  gatewayResponse Json?          @map("gateway_response")
  paidAt          DateTime?      @map("paid_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([gateway])
  @@index([status])
  @@index([gatewayTxnId])
  @@map("payments")
}

model Payout {
  id          String       @id @default(uuid())
  creatorId   String       @map("creator_id")
  amount      Decimal      @db.Decimal(12, 2)
  currency    String       @default("BDT") @db.VarChar(3)
  method      PayoutMethod
  status      PayoutStatus @default(PENDING)
  reference   String?      @db.VarChar(255)
  processedAt DateTime?    @map("processed_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  creator CreatorProfile @relation(fields: [creatorId], references: [id])

  @@index([creatorId])
  @@index([status])
  @@map("payouts")
}

model Review {
  id                 String   @id @default(uuid())
  productId          String   @map("product_id")
  userId             String   @map("user_id")
  rating             Int
  title              String?  @db.VarChar(255)
  body               String?
  images             String[]
  isVerifiedPurchase Boolean  @default(false) @map("is_verified_purchase")
  createdAt          DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([productId, userId])
  @@index([rating])
  @@map("reviews")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("favorites")
}

model Cart {
  id     String     @id @default(uuid())
  userId String     @unique @map("user_id")
  items  CartItem[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String   @map("cart_id")
  productId String   @map("product_id")
  variantId String   @map("variant_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@map("cart_items")
}

model AffiliateLink {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  creatorId         String?  @map("creator_id")
  productId         String?  @map("product_id")
  storeId           String?  @map("store_id")
  code              String   @unique @db.VarChar(20)
  linkType          String   @default("PRODUCT") @map("link_type") @db.VarChar(20)
  commissionPercent Decimal  @default(10) @map("commission_percent") @db.Decimal(5, 2)
  clickCount        Int      @default(0) @map("click_count")
  conversionCount   Int      @default(0) @map("conversion_count")
  totalEarned       Decimal  @default(0) @map("total_earned") @db.Decimal(12, 2)
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  user    User            @relation(fields: [userId], references: [id])
  creator CreatorProfile? @relation(fields: [creatorId], references: [id])
  product Product?        @relation(fields: [productId], references: [id])

  @@index([userId])
  @@index([creatorId])
  @@index([productId])
  @@map("affiliate_links")
}

model Subscription {
  id           String             @id @default(uuid())
  creatorId    String             @unique @map("creator_id")
  plan         SubscriptionTier
  status       SubscriptionStatus @default(ACTIVE)
  startedAt    DateTime           @map("started_at")
  expiresAt    DateTime?          @map("expires_at")
  gateway      String?            @db.VarChar(50)
  gatewaySubId String?            @map("gateway_sub_id") @db.VarChar(255)

  creator CreatorProfile @relation(fields: [creatorId], references: [id])

  @@map("subscriptions")
}

model Coupon {
  id            String       @id @default(uuid())
  code          String       @unique @db.VarChar(30)
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @map("discount_value") @db.Decimal(10, 2)
  minOrderValue Decimal      @default(0) @map("min_order_value") @db.Decimal(10, 2)
  maxUses       Int?         @map("max_uses")
  usedCount     Int          @default(0) @map("used_count")
  validFrom     DateTime     @map("valid_from")
  validUntil    DateTime?    @map("valid_until")
  isActive      Boolean      @default(true) @map("is_active")

  @@map("coupons")
}

model AnalyticsEvent {
  id         String   @id @default(uuid())
  eventType  String   @map("event_type") @db.VarChar(50)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id")
  userId     String?  @map("user_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([eventType])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("analytics_events")
}

model NotificationLog {
  id      String              @id @default(uuid())
  userId  String              @map("user_id")
  type    NotificationType
  channel NotificationChannel
  title   String              @db.VarChar(255)
  body    String
  isRead  Boolean             @default(false) @map("is_read")
  sentAt  DateTime            @default(now()) @map("sent_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notification_logs")
}

model UploadedImage {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  originalUrl  String   @map("original_url")
  thumbnailUrl String?  @map("thumbnail_url")
  mediumUrl    String?  @map("medium_url")
  largeUrl     String?  @map("large_url")
  mimeType     String   @map("mime_type") @db.VarChar(50)
  sizeBytes    Int      @map("size_bytes")
  width        Int?
  height       Int?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("uploaded_images")
}
